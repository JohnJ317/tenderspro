# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL="postgresql://tenderpro:tenderpro@localhost:5432/tenderpro?schema=public"
DATABASE_URL_ADMIN="postgresql://tenderpro_admin:tenderpro_admin@localhost:5432/tenderpro?schema=public"

# JWT
JWT_SECRET="dev-secret-change-me-64-chars-minimum-xyzabc123456789abcdefghijklmno"
JWT_EXPIRES_IN="12h"

# Bcrypt
BCRYPT_ROUNDS=12

# Email (Resend - https://resend.com)
# Crée une clé API sur Resend, vérifie ton domaine, et copie la clé ici
RESEND_API_KEY=

# Identité de l'expéditeur des emails (utilisé par Resend)
SMTP_FROM=support@mytenderspro.com
SMTP_FROM_NAME=TenderPro

# URL publique du frontend (utilisée dans les liens d'invitation)
APP_URL=https://mytenderspro.com

# CORS — origines autorisées (CSV). Si vide, fallback sur la liste dans main.ts
CORS_ORIGINS=

# S3 / MinIO storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=tenderpro
S3_SECRET_KEY=tenderpro_secret_dev
S3_BUCKET=tenderpro
S3_FORCE_PATH_STYLE=true
S3_DOWNLOAD_URL_EXPIRES=604800


# Redis (cache cookies J360 — 7 jours)
# En prod (Railway/Heroku) : utiliser REDIS_URL fourni par le service managé.
# En dev local : laisser REDIS_URL vide et utiliser REDIS_HOST/REDIS_PORT
# (docker-compose expose Redis sur localhost:6379).
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cron externe — secret pour authentifier les appels POST /api/cron/*
# (Railway Cron Jobs, cron-job.org, etc.). Si vide, tous les appels cron
# sont refusés. Générer avec : openssl rand -hex 32
CRON_SECRET=

# Wave webhook signature (HMAC SHA-256, format Wave officiel)
# Secret généré par Wave Business Portal lors de la création du webhook
# Format : wave_sn_WHS_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Si vide en dev → check HMAC désactivé (avec warning dans les logs)
# OBLIGATOIRE en production.
WAVE_WEBHOOK_SECRET=
