model Subscription {
  id                  String             @id @default(uuid()) @db.Uuid
  cabinetId           String             @unique @map("cabinet_id") @db.Uuid
  status              SubscriptionStatus @default(TRIAL)
  currentPeriodStart  DateTime?          @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd    DateTime?          @map("current_period_end") @db.Timestamptz(6)
  nextBillingDate     DateTime?          @map("next_billing_date") @db.Timestamptz(6)
  lastPaidAt          DateTime?          @map("last_paid_at") @db.Timestamptz(6)
  monthlyAmountFcfa   Decimal            @default(15000) @map("monthly_amount_fcfa") @db.Decimal(15, 2)
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  cabinet  Cabinet   @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  payments Payment[]
  notifications SubscriptionNotificationSent[]

  @@map("subscriptions")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  cabinetId         String        @map("cabinet_id") @db.Uuid
  subscriptionId    String?       @map("subscription_id") @db.Uuid
  amountFcfa        Decimal       @map("amount_fcfa") @db.Decimal(15, 2)
  method            PaymentMethod @default(WAVE)
  status            PaymentStatus @default(PENDING)
  reference         String?       @db.VarChar(200)
  waveTransactionId String?       @unique @map("wave_transaction_id") @db.VarChar(200)
  paidAt            DateTime?     @map("paid_at") @db.Timestamptz(6)
  periodStart       DateTime?     @map("period_start") @db.Timestamptz(6)
  periodEnd         DateTime?     @map("period_end") @db.Timestamptz(6)
  notes             String?       @db.Text
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  
  cabinet      Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  webhookEvents WebhookEventProcessed[]

  @@index([cabinetId, createdAt])
  @@map("payments")
}

model CommissionInvoice {
  id                   String           @id @default(uuid()) @db.Uuid
  cabinetId            String           @map("cabinet_id") @db.Uuid
  tenderId             String           @unique @map("tender_id") @db.Uuid
  wonAmountFcfa        Decimal          @map("won_amount_fcfa") @db.Decimal(15, 2)
  commissionRate       Decimal          @map("commission_rate") @db.Decimal(5, 4)
  commissionAmountFcfa Decimal          @map("commission_amount_fcfa") @db.Decimal(15, 2)
  status               CommissionStatus @default(PENDING)
  invoicedAt           DateTime?        @map("invoiced_at") @db.Timestamptz(6)
  paidAt               DateTime?        @map("paid_at") @db.Timestamptz(6)
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  cabinet Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  tender  Tender  @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@map("commission_invoices")
}

model WebhookEventProcessed {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @unique @map("event_id") @db.VarChar(200)
  eventType   String   @map("event_type") @db.VarChar(100)
  source      String   @default("wave") @db.VarChar(50)
  paymentId   String?  @map("payment_id") @db.Uuid
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([processedAt])
  @@map("webhook_events_processed")
}

model SubscriptionNotificationSent {
  id                  String    @id @default(uuid()) @db.Uuid
  subscriptionId      String    @map("subscription_id") @db.Uuid
  cabinetId           String    @map("cabinet_id") @db.Uuid
  notificationType    String    @map("notification_type") @db.VarChar(50)
  relatedBillingDate  DateTime? @map("related_billing_date") @db.Timestamptz(6)
  sentAt              DateTime  @default(now()) @map("sent_at") @db.Timestamptz(6)
  emailTo             String    @map("email_to") @db.VarChar(200)

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  cabinet      Cabinet      @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, notificationType, relatedBillingDate])
  @@index([subscriptionId])
  @@index([sentAt])
  @@map("subscription_notifications_sent")
}