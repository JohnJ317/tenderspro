// Sprint 5a — Veille automatique
// À ajouter à la fin de prisma/schema.prisma (après les modèles existants).
// Ajouter aussi la relation sur Cabinet et Tender en suivant les commentaires.
// ============================================================================

enum ScrapedTenderStatus {
  NEW
  MATCHED
  IGNORED
  PROMOTED
  DISMISSED
}

enum AlertType {
  NEW_MATCH
  DEADLINE_APPROACHING
  SOURCE_ERROR
}

enum ScraperStatus {
  SUCCESS
  PARTIAL
  FAILED
  SKIPPED
}

model WatchDomain {
  id              String   @id @default(uuid()) @db.Uuid
  cabinetId       String   @map("cabinet_id") @db.Uuid
  name            String   @db.VarChar(200)
  keywords        String[] @default([])
  sectors         String[] @default([])
  countries       String[] @default([])
  sources         String[] @default([])
  minBudget       Decimal? @map("min_budget") @db.Decimal(15, 2)
  maxBudget       Decimal? @map("max_budget") @db.Decimal(15, 2)
  includeTenders  Boolean  @default(true) @map("include_tenders")
  includeEoi      Boolean  @default(true) @map("include_eoi")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  cabinet         Cabinet  @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  @@index([cabinetId])
  @@index([isActive])
  @@map("watch_domains")
}

model ScrapedTender {
  id                  String               @id @default(uuid()) @db.Uuid
  source              String               @db.VarChar(50)
  externalRef         String?              @map("external_ref") @db.VarChar(300)
  title               String               @db.Text
  description         String?              @db.Text
  clientName          String?              @map("client_name") @db.VarChar(500)
  sector              String?              @db.VarChar(300)
  country             String?              @db.VarChar(50)
  publishedAt         DateTime?            @map("published_at") @db.Timestamptz(6)
  submissionDeadline  DateTime?            @map("submission_deadline") @db.Timestamptz(6)
  budgetIndicative    Decimal?             @map("budget_indicative") @db.Decimal(15, 2)
  currency            String?              @db.VarChar(3)
  sourceUrl           String?              @map("source_url") @db.Text
  documentUrls        String[]             @default([]) @map("document_urls")
  isEoi               Boolean              @default(false) @map("is_eoi")
  rawData             Json?                @map("raw_data")
  status              ScrapedTenderStatus  @default(NEW)
  matchedCabinetIds   String[]             @default([]) @map("matched_cabinet_ids") @db.Uuid
  promotedTenderId    String?              @map("promoted_tender_id") @db.Uuid
  scrapedAt           DateTime             @default(now()) @map("scraped_at") @db.Timestamptz(6)
  processedAt         DateTime?            @map("processed_at") @db.Timestamptz(6)

  promotedTender      Tender?              @relation("ScrapedTenderPromotion", fields: [promotedTenderId], references: [id], onDelete: SetNull)
  alerts              Alert[]

  @@unique([source, externalRef])
  @@index([status])
  @@index([country])
  @@index([submissionDeadline])
  @@index([scrapedAt(sort: Desc)])
  @@map("scraped_tenders")
}

model Alert {
  id              String     @id @default(uuid()) @db.Uuid
  cabinetId       String     @map("cabinet_id") @db.Uuid
  type            AlertType
  title           String     @db.VarChar(500)
  message         String?    @db.Text
  scrapedTenderId String?    @map("scraped_tender_id") @db.Uuid
  tenderId        String?    @map("tender_id") @db.Uuid
  readAt          DateTime?  @map("read_at") @db.Timestamptz(6)
  emailSentAt     DateTime?  @map("email_sent_at") @db.Timestamptz(6)
  dismissedAt     DateTime?  @map("dismissed_at") @db.Timestamptz(6)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  cabinet         Cabinet        @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  scrapedTender   ScrapedTender? @relation(fields: [scrapedTenderId], references: [id], onDelete: SetNull)
  tender          Tender?        @relation("TenderAlerts", fields: [tenderId], references: [id], onDelete: SetNull)

  @@index([cabinetId])
  @@index([cabinetId, readAt])
  @@index([createdAt(sort: Desc)])
  @@map("alerts")
}

model ScraperRun {
  id            String         @id @default(uuid()) @db.Uuid
  source        String         @db.VarChar(50)
  startedAt     DateTime       @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt    DateTime?      @map("finished_at") @db.Timestamptz(6)
  status        ScraperStatus  @default(SUCCESS)
  itemsFound    Int            @default(0) @map("items_found")
  itemsNew      Int            @default(0) @map("items_new")
  itemsError    Int            @default(0) @map("items_error")
  errorMessage  String?        @map("error_message") @db.Text

  @@index([source, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
  @@map("scraper_runs")
}

model J360Config {
