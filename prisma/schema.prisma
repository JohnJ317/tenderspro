// Prisma schema - Sprint 3 (pricing engine)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_ADMIN")
}

enum CabinetStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum Country {
  CI
  SN
  BF
  ML
  TG
  BJ
  NE
  GW
  CM
  GA
  CD
  MG
  OTHER
}

enum Role {
  ADMIN_CABINET
  ASSOCIE
  MANAGER
  CONSULTANT
  SUPER_ADMIN
}

enum Grade {
  ASSOCIE
  MANAGER
  SENIOR
  JUNIOR
  ASSISTANT
}

enum ActivityType {
  CAC
  AUDIT_CONTRACTUEL
  EC_TENUE
  EC_ETATS_FINANCIERS
  DUE_DILIGENCE
  AUDIT_BAILLEUR
  CONSEIL_FISCAL
  EVALUATION
  CONSEIL_FINANCIER
  AUTRE
}

enum TenderStage {
  WATCHING
  QUALIFICATION
  EOI
  SHORTLISTED
  PREPARING
  SUBMITTED
  NEGOTIATION
  WON
  LOST
  CANCELLED
}

enum TenderSource {
  SIGMAP
  WORLD_BANK
  AFDB
  BOAD
  EU
  AFD
  USAID
  GIZ
  UNGM
  PRIVATE
  OTHER
}

enum TenderType {
  AMI
  AAP
  DIRECT
  RESTRICTED
  OPEN
  PREQUAL
}

enum EventType {
  CONFERENCE
  SALON
  TRAINING
  NETWORKING
  CLIENT_MEETING
  WEBINAR
  OTHER
}

enum EventStage {
  IDENTIFIED
  REGISTERED
  ATTENDED
  FOLLOW_UP
  ROI_MEASURED
  CANCELLED
}

enum TenderDocumentCategory {
  DCE
  TDR
  METHODOLOGIE
  CV
  OFFRE_TECHNIQUE
  OFFRE_FINANCIERE
  ANNEXE
  DECISION_ATTRIBUTION
  CONTRAT
  CORRESPONDANCE
  AUTRE
}

enum EventDocumentCategory {
  PROGRAMME
  INVITATION
  CARTE_VISITE
  COMPTE_RENDU
  PHOTO
  AUTRE
}

enum PricingCoefficientCategory {
  SECTOR
  COMPLEXITY
  URGENCY
  RECURRENCE
  STRATEGIC
  VOLUME
  GEOGRAPHY
  CUSTOM
}

enum CompetitiveIntelSource {
  OFFICIAL_NOTIFICATION
  PUBLIC_ANNOUNCEMENT
  RUMOR
  SELF_REPORTED
  OTHER
}

model Cabinet {
  id            String          @id @default(uuid()) @db.Uuid
  name          String          @db.VarChar(200)
  country       Country         @default(CI)
  currency      String          @default("XOF") @db.VarChar(3)
  vatRate       Decimal         @default(0.18) @db.Decimal(5, 4)
  language      String          @default("fr") @db.VarChar(5)
  status        CabinetStatus   @default(TRIAL)
  deletedAt     DateTime?       @map("deleted_at") @db.Timestamptz(6)
  createdAt     DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @db.Timestamptz(6)
  platformCommissionRate Decimal? @default(0) @map("platform_commission_rate") @db.Decimal(5, 4)

  users         User[]
  activities    Activity[]
  grilleHoraire GrilleHoraire[]
  tenders       Tender[]
  events        Event[]
  coefficients  PricingCoefficient[]
  watchDomains  WatchDomain[]
  alerts        Alert[]
  j360Config    J360Config?
  consultants   Consultant[]
  references    Reference[]
  proposalTemplates ProposalTemplate[]
  subscription       Subscription?
  payments           Payment[]
  usageLogs          ClaudeUsageLog[]
  commissionInvoices CommissionInvoice[]
  subscriptionNotifications SubscriptionNotificationSent[]


  logoUrl       String?         @map("logo_url") @db.Text
  
  

  @@index([status])
  @@map("cabinets")
  
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  cabinetId    String    @map("cabinet_id") @db.Uuid
  email        String    @db.VarChar(320)
  passwordHash String?   @map("password_hash") @db.VarChar(255)
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  role         Role
  grade        Grade?
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  cabinet                    Cabinet            @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  tendersLed                 Tender[]           @relation("TenderLead")
  tendersCreated             Tender[]           @relation("TenderCreator")
  tenderTransitions          TenderTransition[] @relation("TenderTransitionUser")
  tenderDocumentsUploaded    TenderDocument[]   @relation("TenderDocumentUploader")
  eventsLed                  Event[]            @relation("EventLead")
  eventsCreated              Event[]            @relation("EventCreator")
  eventTransitions           EventTransition[]  @relation("EventTransitionUser")
  eventDocumentsUploaded     EventDocument[]    @relation("EventDocumentUploader")
  tenderPricingsCreated      TenderPricing[]    @relation("TenderPricingCreator")
  competitiveIntelsCreated   CompetitiveIntel[] @relation("CompetitiveIntelCreator")
  claudeUsageLogs            ClaudeUsageLog[]

  invitationToken     String?   @map("invitation_token")
  invitationExpiresAt DateTime? @map("invitation_expires_at") @db.Timestamptz(6)
  invitedById         String?   @map("invited_by_id") @db.Uuid
  invitedAt           DateTime? @map("invited_at") @db.Timestamptz(6)
  invitedBy           User?     @relation("UserInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers        User[]    @relation("UserInviter")

  @@unique([cabinetId, email])
  @@index([cabinetId])
  @@map("users")
}

model Activity {
  id        String       @id @default(uuid()) @db.Uuid
  cabinetId String       @map("cabinet_id") @db.Uuid
  type      ActivityType
  label     String       @db.VarChar(200)
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  cabinet   Cabinet      @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  @@index([cabinetId])
  @@map("activities")
}

model GrilleHoraire {
  id            String    @id @default(uuid()) @db.Uuid
  cabinetId     String    @map("cabinet_id") @db.Uuid
  grade         Grade
  hourlyRate    Decimal   @map("hourly_rate") @db.Decimal(12, 2)
  dailyRate     Decimal?  @map("daily_rate") @db.Decimal(12, 2)
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  cabinet       Cabinet   @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  @@index([cabinetId, grade, effectiveFrom])
  @@map("grille_horaire")
}

model Tender {
  id                 String       @id @default(uuid()) @db.Uuid
  cabinetId          String       @map("cabinet_id") @db.Uuid
  reference          String?      @db.VarChar(100)
  title              String       @db.VarChar(500)
  description        String?      @db.Text
  clientName         String?      @map("client_name") @db.VarChar(300)
  sector             String?      @db.VarChar(200)
  source             TenderSource @default(OTHER)
  type               TenderType   @default(OPEN)
  country            Country?
  stage              TenderStage  @default(WATCHING)
  isOpen             Boolean      @default(true) @map("is_open")
  publishedAt        DateTime?    @map("published_at") @db.Timestamptz(6)
  submissionDeadline DateTime?    @map("submission_deadline") @db.Timestamptz(6)
  decisionExpectedAt DateTime?    @map("decision_expected_at") @db.Timestamptz(6)
  startDate          DateTime?    @map("start_date") @db.Date
  budgetIndicative   Decimal?     @map("budget_indicative") @db.Decimal(15, 2)
  ourProposedAmount  Decimal?     @map("our_proposed_amount") @db.Decimal(15, 2)
  wonAmount          Decimal?     @map("won_amount") @db.Decimal(15, 2)
  currency           String       @default("XOF") @db.VarChar(3)
  sourceUrl          String?      @map("source_url") @db.Text
  leadUserId         String?      @map("lead_user_id") @db.Uuid
  lostReason         String?      @map("lost_reason") @db.Text
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById        String?      @map("created_by_id") @db.Uuid

  cabinet            Cabinet            @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  leadUser           User?              @relation("TenderLead", fields: [leadUserId], references: [id], onDelete: SetNull)
  createdBy          User?              @relation("TenderCreator", fields: [createdById], references: [id], onDelete: SetNull)
  transitions        TenderTransition[]
  documents          TenderDocument[]
  pricings           TenderPricing[]
  competitiveIntels  CompetitiveIntel[]
  analysis           TenderAnalysis?
  proposal           TenderProposal?
  commissionInvoice  CommissionInvoice?
  promotedFromScrapes  ScrapedTender[]  @relation("ScrapedTenderPromotion")
  alertsRef            Alert[]          @relation("TenderAlerts")

  @@index([cabinetId, stage])
  @@index([cabinetId, isOpen])
  @@index([cabinetId, submissionDeadline])
  @@index([cabinetId, leadUserId])
  @@map("tenders")

}

model TenderTransition {
  id            String       @id @default(uuid()) @db.Uuid
  tenderId      String       @map("tender_id") @db.Uuid
  fromStage     TenderStage? @map("from_stage")
  toStage       TenderStage  @map("to_stage")
  note          String?      @db.Text
  performedById String?      @map("performed_by_id") @db.Uuid
  performedAt   DateTime     @default(now()) @map("performed_at") @db.Timestamptz(6)

  tender        Tender       @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  performedBy   User?        @relation("TenderTransitionUser", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([tenderId, performedAt])
  @@map("tender_transitions")
}

model TenderDocument {
  id           String                 @id @default(uuid()) @db.Uuid
  tenderId     String                 @map("tender_id") @db.Uuid
  category     TenderDocumentCategory @default(AUTRE)
  filename     String                 @db.VarChar(500)
  mimeType     String                 @map("mime_type") @db.VarChar(200)
  sizeBytes    BigInt                 @map("size_bytes")
  s3Key        String                 @unique @map("s3_key") @db.VarChar(500)
  description  String?                @db.Text
  uploadedById String?                @map("uploaded_by_id") @db.Uuid
  uploadedAt   DateTime               @default(now()) @map("uploaded_at") @db.Timestamptz(6)

  tender       Tender                 @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  uploadedBy   User?                  @relation("TenderDocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([tenderId, category])
  @@map("tender_documents")
}

model Event {
  id               String     @id @default(uuid()) @db.Uuid
  cabinetId        String     @map("cabinet_id") @db.Uuid
  title            String     @db.VarChar(500)
  description      String?    @db.Text
  type             EventType  @default(CONFERENCE)
  startsAt         DateTime   @map("starts_at") @db.Timestamptz(6)
  endsAt           DateTime?  @map("ends_at") @db.Timestamptz(6)
  location         String?    @db.VarChar(300)
  city             String?    @db.VarChar(100)
  country          Country?
  isVirtual        Boolean    @default(false) @map("is_virtual")
  stage            EventStage @default(IDENTIFIED)
  registrationCost Decimal?   @map("registration_cost") @db.Decimal(12, 2)
  travelCost       Decimal?   @map("travel_cost") @db.Decimal(12, 2)
  currency         String     @default("XOF") @db.VarChar(3)
  expectedLeads    Int?       @map("expected_leads")
  actualLeads      Int?       @map("actual_leads")
  convertedLeads   Int?       @map("converted_leads")
  roiNotes         String?    @map("roi_notes") @db.Text
  url              String?    @db.Text
  leadUserId       String?    @map("lead_user_id") @db.Uuid
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById      String?    @map("created_by_id") @db.Uuid

  cabinet          Cabinet           @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  leadUser         User?             @relation("EventLead", fields: [leadUserId], references: [id], onDelete: SetNull)
  createdBy        User?             @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  transitions      EventTransition[]
  documents        EventDocument[]

  @@index([cabinetId, stage])
  @@index([cabinetId, startsAt])
  @@map("events")
}

model EventTransition {
  id            String      @id @default(uuid()) @db.Uuid
  eventId       String      @map("event_id") @db.Uuid
  fromStage     EventStage? @map("from_stage")
  toStage       EventStage  @map("to_stage")
  note          String?     @db.Text
  performedById String?     @map("performed_by_id") @db.Uuid
  performedAt   DateTime    @default(now()) @map("performed_at") @db.Timestamptz(6)

  event         Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  performedBy   User?       @relation("EventTransitionUser", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([eventId, performedAt])
  @@map("event_transitions")
}

model EventDocument {
  id           String                @id @default(uuid()) @db.Uuid
  eventId      String                @map("event_id") @db.Uuid
  category     EventDocumentCategory @default(AUTRE)
  filename     String                @db.VarChar(500)
  mimeType     String                @map("mime_type") @db.VarChar(200)
  sizeBytes    BigInt                @map("size_bytes")
  s3Key        String                @unique @map("s3_key") @db.VarChar(500)
  description  String?               @db.Text
  uploadedById String?               @map("uploaded_by_id") @db.Uuid
  uploadedAt   DateTime              @default(now()) @map("uploaded_at") @db.Timestamptz(6)

  event        Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploadedBy   User?                 @relation("EventDocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([eventId, category])
  @@map("event_documents")
}

// ============================================================================
// Sprint 3 — Pricing & Competitive Intelligence
// ============================================================================

model PricingCoefficient {
  id          String                     @id @default(uuid()) @db.Uuid
  cabinetId   String                     @map("cabinet_id") @db.Uuid
  code        String                     @db.VarChar(100)
  label       String                     @db.VarChar(200)
  category    PricingCoefficientCategory
  multiplier  Decimal                    @db.Decimal(5, 3)
  description String?                    @db.Text
  isSystem    Boolean                    @default(false) @map("is_system")
  isActive    Boolean                    @default(true) @map("is_active")
  sortOrder   Int                        @default(0) @map("sort_order")
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  cabinet     Cabinet                    @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  @@unique([cabinetId, code])
  @@index([cabinetId, category])
  @@map("pricing_coefficients")
}

model TenderPricing {
  id                   String   @id @default(uuid()) @db.Uuid
  tenderId             String   @map("tender_id") @db.Uuid
  name                 String   @db.VarChar(200)
  associeHours         Decimal  @default(0) @map("associe_hours") @db.Decimal(8, 2)
  managerHours         Decimal  @default(0) @map("manager_hours") @db.Decimal(8, 2)
  seniorHours          Decimal  @default(0) @map("senior_hours") @db.Decimal(8, 2)
  juniorHours          Decimal  @default(0) @map("junior_hours") @db.Decimal(8, 2)
  assistantHours       Decimal  @default(0) @map("assistant_hours") @db.Decimal(8, 2)
  travelCost           Decimal  @default(0) @map("travel_cost") @db.Decimal(15, 2)
  otherCosts           Decimal  @default(0) @map("other_costs") @db.Decimal(15, 2)
  otherCostsLabel      String?  @map("other_costs_label") @db.VarChar(200)
  coefficientsSnapshot Json     @map("coefficients_snapshot")
  floorMarginRate      Decimal  @default(0.10) @map("floor_margin_rate") @db.Decimal(5, 4)
  targetMarginRate     Decimal  @default(0.25) @map("target_margin_rate") @db.Decimal(5, 4)
  ceilingMarginRate    Decimal  @default(0.40) @map("ceiling_margin_rate") @db.Decimal(5, 4)
  baseCost             Decimal  @map("base_cost") @db.Decimal(15, 2)
  adjustedCost         Decimal  @map("adjusted_cost") @db.Decimal(15, 2)
  floorPrice           Decimal  @map("floor_price") @db.Decimal(15, 2)
  targetPrice          Decimal  @map("target_price") @db.Decimal(15, 2)
  ceilingPrice         Decimal  @map("ceiling_price") @db.Decimal(15, 2)
  currency             String   @default("XOF") @db.VarChar(3)
  notes                String?  @db.Text
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById          String?  @map("created_by_id") @db.Uuid
  proposals         TenderProposal[] @relation("ProposalPricing")

  tender               Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  createdBy            User?    @relation("TenderPricingCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenderId])
  @@map("tender_pricings")
}

model CompetitiveIntel {
  id              String                 @id @default(uuid()) @db.Uuid
  tenderId        String                 @map("tender_id") @db.Uuid
  competitorName  String                 @map("competitor_name") @db.VarChar(200)
  competitorPrice Decimal?               @map("competitor_price") @db.Decimal(15, 2)
  currency        String                 @default("XOF") @db.VarChar(3)
  isWinner        Boolean                @default(false) @map("is_winner")
  source          CompetitiveIntelSource @default(OTHER)
  notes           String?                @db.Text
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById     String?                @map("created_by_id") @db.Uuid

  tender          Tender                 @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  createdBy       User?                  @relation("CompetitiveIntelCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenderId])
  @@index([competitorName])
  @@map("competitive_intels")
}
